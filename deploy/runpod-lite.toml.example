[runpod]
name = "character-eng-session-manager-lite"
gpu_type_ids = ["NVIDIA GeForce RTX 4090", "NVIDIA GeForce RTX 5090", "NVIDIA L40S"]
gpu_count = 1
gpu_type_priority = "custom"
data_center_ids = ["US-CA-2", "US-WA-1", "US-TX-4"]
data_center_priority = "custom"
cloud_type = "SECURE"
compute_type = "GPU"
interruptible = false
container_disk_in_gb = 30
volume_in_gb = 10
volume_mount_path = "/workspace"
support_public_ip = true

[image]
name = "ghcr.io/your-org/character-eng:runpod-lite"

[registry_auth]
name = "ghcr-character-eng"
username_env = "GHCR_USERNAME"
password_env = "GHCR_PASSWORD"

[network]
ports = ["7870/http", "22/tcp"]
manager_port = 7870
session_bridge_port = 7862

[env]
PUBLIC_HOST = ""
MANAGER_PORT = "7870"
CHARACTER_ENG_SESSION_DEFAULT_VISION = "false"
CHARACTER_ENG_SESSION_ALLOW_VISION = "false"
CHARACTER_ENG_SESSION_RUNTIME = "stub"

[files]
state_path = ".runpod-lite-state.json"
