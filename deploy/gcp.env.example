GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-west1
GCP_ZONE=us-west1-a
GCP_INSTANCE_NAME=character-eng-gpu
GCP_MACHINE_TYPE=g2-standard-8
GCP_ACCELERATOR_TYPE=nvidia-l4
GCP_ACCELERATOR_COUNT=1
GCP_BOOT_DISK_SIZE_GB=200
GCP_RUNTIME_DISK_NAME=character-eng-runtime
GCP_RUNTIME_DISK_SIZE_GB=200
GCP_RUNTIME_MOUNT_PATH=/mnt/disks/character-eng-runtime
GCP_SOURCE_IMAGE_PROJECT=ml-images
GCP_SOURCE_IMAGE_FAMILY=common-cu128-ubuntu-2204-nvidia-570
GCP_ADDRESS_NAME=character-eng-ip
GCP_NETWORK=default
GCP_TAGS=character-eng-gpu

CONTAINER_IMAGE=ghcr.io/your-org/character-eng:latest
CONTAINER_NAME=character-eng
CONTAINER_MODE=full
MANAGER_PORT=7870
WORKSPACE_MOUNT_PATH=/workspace
CHARACTER=greg
START_PAUSED=1
CHARACTER_ENG_SHARED_VISION_URL=http://127.0.0.1:7860
VLLM_GPU_UTIL=0.75
POCKET_HOST=0.0.0.0
AUTO_SHUTDOWN_ENABLED=0
AUTO_SHUTDOWN_TIME=02:00
AUTO_SHUTDOWN_TIMEZONE=America/Los_Angeles

# For real browser mic/camera access, set a public hostname with HTTPS.
PUBLIC_HOST=
CADDY_DOMAIN=
CADDY_LIVEKIT_DOMAIN=
CADDY_EMAIL=

# Prefer GCP Secret Manager refs for shared remote use so collaborators do not
# need local copies of the API keys. Each GCP_SECRET_* value may be:
# - secret-name
# - secret-name:version
# - projects/<project>/secrets/<name>/versions/<version>
# Direct *_API_KEY values still work as a fallback.
HF_TOKEN=
CEREBRAS_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
CHARACTER_ENG_MANAGER_TOKEN=
GCP_SECRET_HF_TOKEN=
GCP_SECRET_CEREBRAS_API_KEY=
GCP_SECRET_GROQ_API_KEY=
GCP_SECRET_GEMINI_API_KEY=
GCP_SECRET_DEEPGRAM_API_KEY=
GCP_SECRET_ELEVENLABS_API_KEY=

LIVEKIT_ENABLED=1
LIVEKIT_IMAGE=livekit/livekit-server:latest
LIVEKIT_HTTP_PORT=7880
LIVEKIT_TCP_PORT=7881
LIVEKIT_UDP_START=50100
LIVEKIT_UDP_END=50120
# Use a real key/secret pair for shared rooms. The secret should be 32+ chars.
# Prefer GCP_SECRET_LIVEKIT_API_KEY / GCP_SECRET_LIVEKIT_API_SECRET for shared use.
LIVEKIT_API_KEY=character-eng-livekit
LIVEKIT_API_SECRET=replace-with-a-random-32-plus-char-secret
GCP_SECRET_LIVEKIT_API_KEY=
GCP_SECRET_LIVEKIT_API_SECRET=

# Leave blank when pulling from Artifact Registry with the VM's service account.
REGISTRY_SERVER=ghcr.io
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
