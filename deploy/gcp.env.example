GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-west1
GCP_ZONE=us-west1-a
GCP_INSTANCE_NAME=character-eng-gpu
GCP_MACHINE_TYPE=g2-standard-8
GCP_ACCELERATOR_TYPE=nvidia-l4
GCP_ACCELERATOR_COUNT=1
GCP_BOOT_DISK_SIZE_GB=200
GCP_RUNTIME_DISK_NAME=character-eng-runtime
GCP_RUNTIME_DISK_SIZE_GB=200
GCP_RUNTIME_MOUNT_PATH=/mnt/disks/character-eng-runtime
GCP_SOURCE_IMAGE_PROJECT=ml-images
GCP_SOURCE_IMAGE_FAMILY=common-cu128-ubuntu-2204-nvidia-570
GCP_ADDRESS_NAME=character-eng-ip
GCP_NETWORK=default
GCP_TAGS=character-eng-gpu

CONTAINER_IMAGE=ghcr.io/your-org/character-eng:latest
CONTAINER_NAME=character-eng
CONTAINER_MODE=full
MANAGER_PORT=7870
WORKSPACE_MOUNT_PATH=/workspace
CHARACTER=greg
START_PAUSED=1
CHARACTER_ENG_SHARED_VISION_URL=http://127.0.0.1:7860
VLLM_GPU_UTIL=0.75
POCKET_HOST=0.0.0.0

# For real browser mic/camera access, set a public hostname with HTTPS.
PUBLIC_HOST=
CADDY_DOMAIN=
CADDY_LIVEKIT_DOMAIN=
CADDY_EMAIL=

HF_TOKEN=
CHARACTER_ENG_MANAGER_TOKEN=

LIVEKIT_ENABLED=1
LIVEKIT_IMAGE=livekit/livekit-server:latest
LIVEKIT_HTTP_PORT=7880
LIVEKIT_TCP_PORT=7881
LIVEKIT_UDP_START=50100
LIVEKIT_UDP_END=50120
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Leave blank when pulling from Artifact Registry with the VM's service account.
REGISTRY_SERVER=ghcr.io
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
