[runpod]
name = "character-eng-session-manager"
gpu_type_ids = ["NVIDIA GeForce RTX 4090"]
gpu_count = 1
gpu_type_priority = "availability"
data_center_ids = ["US-CA-2", "US-WA-1", "US-TX-4", "US-TX-3", "US-IL-1", "US-KS-2", "US-GA-1", "US-GA-2", "US-NC-1"]
data_center_priority = "custom"
cloud_type = "SECURE"
compute_type = "GPU"
interruptible = false
container_disk_in_gb = 50
volume_in_gb = 80
volume_mount_path = "/workspace"
support_public_ip = true

[image]
name = "ghcr.io/your-org/character-eng:latest"

[registry_auth]
name = "ghcr-character-eng"
username_env = "GHCR_USERNAME"
password_env = "GHCR_PASSWORD"

[network]
ports = ["7870/http", "22/tcp"]
manager_port = 7870
session_bridge_port = 7862

[env]
MODE = "full"
PUBLIC_HOST = ""
MANAGER_PORT = "7870"
CHARACTER_ENG_SHARED_VISION_URL = "http://127.0.0.1:7860"

[files]
state_path = ".runpod-state.json"
